# Backend Environment Configuration
# Copy this file to .env and set your values

# API host/port
HOST=127.0.0.1
PORT=8005

# CORS: comma-separated list of allowed frontend origins
# Use * for development (allows any origin)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File size limits (in MB)
MAX_IMAGE_MB=10
MAX_VIDEO_MB=200
MAX_AUDIO_MB=50

# Demo mode: if true, returns simulated results instead of running real inference
DEMO_MODE=false
